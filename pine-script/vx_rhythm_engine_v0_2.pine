//@version=5
// =============================================================================
// vX Rhythm Engine™ v0.2 — Traversal Intelligence Layer
// Behavioral state classifier on the Harmonic Rails framework.
// 7 states · 4 normalized scores · replay-safe · non-repainting · modular.
// =============================================================================
indicator("vX Rhythm Engine™ v0.2", shorttitle="vX RHYTHM·v0.2", overlay=true,
     max_lines_count=120, max_labels_count=50, max_boxes_count=20)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
gC = "Adaptive Channel"
chanLen   = input.int(50,  "Channel Length",          minval=10, maxval=500, group=gC)
chanMult  = input.float(2.0,"Channel Width (σ mult)", minval=0.5, maxval=4.0, step=0.1, group=gC)
adaptive  = input.bool(true,"Adaptive Width (ATR-scaled)", group=gC)

gA = "ATR / Normalization"
atrLen    = input.int(14, "ATR Length",          minval=2,  group=gA)
atrSlow   = input.int(50, "ATR Baseline Length", minval=10, group=gA)

gB = "Behavioral Windows"
slopeWin    = input.int(5,  "Slope Window",     minval=2, group=gB)
cadenceLen  = input.int(10, "Cadence Window",   minval=3, group=gB)
effLen      = input.int(10, "Efficiency Window",minval=3, group=gB)
behaviorLen = input.int(10, "Behavior Window",  minval=5, group=gB)

gT = "State Thresholds"
qThresh = input.int(65, "Clean Traversal ≥",  minval=40, maxval=95, group=gT)
cThresh = input.int(65, "Compression Coil ≥", minval=40, maxval=95, group=gT)
xThresh = input.int(65, "Expansion Burst ≥",  minval=40, maxval=95, group=gT)
eThresh = input.int(70, "Exhaustion ≥",       minval=40, maxval=95, group=gT)

gL = "Liquidity Memory"
pivotL    = input.int(5, "Pivot Left",  minval=1, group=gL)
pivotR    = input.int(5, "Pivot Right", minval=1, group=gL)
maxZones  = input.int(8, "Max zones (each side)", minval=2, maxval=20, group=gL)
showZones = input.bool(true, "Show liquidity zones", group=gL)

gV = "Visual"
showChannel = input.bool(true, "Channel",            group=gV)
showFill    = input.bool(true, "Channel fill",       group=gV)
showRibbon  = input.bool(true, "State ribbon (bg)",  group=gV)
colorBars   = input.bool(false,"Color bars by state",group=gV)
showDash    = input.bool(true, "Dashboard",          group=gV)
dashPos     = input.string("top_right", "Dashboard position",
     options=["top_left","top_right","bottom_left","bottom_right"], group=gV)

// ─── PALETTE (institutional dark) ────────────────────────────────────────────
cMid     = color.new(#8a93a3, 50)
cRail    = color.new(#5c6370, 30)
cText    = color.new(#e5e7eb, 0)
cTextDim = color.new(#9aa0a6, 0)
cTextMute= color.new(#6b7280, 0)

cTraversal   = color.new(#06d6a0, 0)
cExpansion   = color.new(#3a86ff, 0)
cCompression = color.new(#f4d35e, 0)
cExhaustion  = color.new(#f4a261, 0)
cFailed      = color.new(#e63946, 0)
cDistortion  = color.new(#d62828, 0)
cDrift       = color.new(#6b7280, 0)
cNeutral     = color.new(#4b5563, 0)

cLqLive  = color.new(#9aa0a6, 30)
cLqTaken = color.new(#9aa0a6, 80)

// ─── HELPERS ─────────────────────────────────────────────────────────────────
clamp01(x) => math.max(0.0, math.min(1.0, x))

makeBar(score) =>
    n = math.round(score / 10)
    s = ""
    for i = 0 to 9
        s := s + (i < n ? "▰" : "▱")
    s

// ─── CORE: ATR + ADAPTIVE CHANNEL ────────────────────────────────────────────
atrF  = ta.atr(atrLen)
atrS  = ta.atr(atrSlow)
atrR  = atrS > 0 ? atrF / atrS : 1.0

mid   = ta.linreg(close, chanLen, 0)
dev   = ta.stdev(close, chanLen)
wMult = adaptive ? chanMult * math.max(0.6, math.min(1.6, atrR)) : chanMult
upper = mid + wMult * dev
lower = mid - wMult * dev
chW   = upper - lower
chWA  = atrF > 0 ? chW / atrF : 0
pos   = chW > 0 ? math.max(0.0, math.min(1.0, (close - lower) / chW)) : 0.5
midPos = dev > 0 ? math.max(-3, math.min(3, (close - mid) / dev)) : 0

slope    = (mid - mid[slopeWin]) / slopeWin
slopA    = atrF > 0 ? slope / atrF : 0
slopAbsA = math.abs(slopA)

// ─── BEHAVIORAL METRICS ──────────────────────────────────────────────────────
ret    = close - close[1]
retA   = atrF > 0 ? ret / atrF : 0
absRet = math.abs(retA)

body    = math.abs(close - open)
rng     = high - low
upWick  = high - math.max(close, open)
loWick  = math.min(close, open) - low
totWick = upWick + loWick
bodyRat = rng > 0 ? body / rng : 0
wickRat = rng > 0 ? totWick / rng : 0

netDisp = math.abs(close - close[effLen])
pathSum = math.sum(math.abs(ret), effLen)
efficiency = pathSum > 0 ? netDisp / pathSum : 0

impulse = absRet > 0.5 ? 1 : 0
cadence = math.sum(impulse, cadenceLen) / cadenceLen
netImp  = math.sum(retA, cadenceLen)
absImpSum = math.sum(absRet, cadenceLen)
directionality = absImpSum > 0 ? math.abs(netImp) / absImpSum : 0

slopeChange    = math.abs(slopA - slopA[slopeWin])
slopeStability = 1.0 / (1.0 + slopeChange * 5.0)

bodyAvg = ta.sma(body, 20)
bodyRel = bodyAvg > 0 ? body / bodyAvg : 1.0

wBase = ta.sma(chWA, 50)
wRel  = wBase > 0 ? chWA / wBase : 1.0

sSign = slopA > 0.02 ? 1 : slopA < -0.02 ? -1 : 0
sFlip = sSign != sSign[1] and sSign != 0 and sSign[1] != 0 ? 1 : 0
flipCount = math.sum(sFlip, behaviorLen)

wickAvg = ta.sma(wickRat, behaviorLen)

absRetF  = ta.ema(absRet, 5)
absRetSm = ta.ema(absRet, 14)
fade     = absRetSm > 0 ? math.max(0.0, 1.0 - absRetF / absRetSm) : 0

rejUp = high >= upper and close < upper - 0.20 * (upper - mid)
rejDn = low  <= lower and close > lower + 0.20 * (mid - lower)
rejCnt = math.sum((rejUp or rejDn) ? 1 : 0, behaviorLen)

midX = (ta.crossover(close, mid) or ta.crossunder(close, mid)) ? 1 : 0
midCrosses = math.sum(midX, 15)

// ─── SCORES (0–100) ──────────────────────────────────────────────────────────
qualityRaw    = 0.30*slopeStability + 0.30*efficiency + 0.20*bodyRat + 0.20*directionality
qualityScore  = math.round(clamp01(qualityRaw) * 100)

widthShrink   = clamp01(1.0 - wRel)
atrShrink     = clamp01(1.0 - atrR)
bodyShrink    = clamp01(1.0 - bodyRel)
cadLow        = clamp01(1.0 - cadence)
compressRaw   = 0.30*widthShrink + 0.30*atrShrink + 0.20*bodyShrink + 0.20*cadLow
compressScore = math.round(clamp01(compressRaw) * 100)

var int compressBars = 0
compressBars := compressScore >= cThresh ? compressBars + 1 : 0

widthExpand    = clamp01(wRel - 1.0)
atrExpand      = clamp01(atrR - 1.0)
slopeAccel     = clamp01((slopAbsA - math.abs(slopA[5])) * 8)
priorCompr     = compressBars[3] >= 3 ? 1.0 : 0.4
expansionRaw   = 0.30*widthExpand + 0.25*atrExpand + 0.25*slopeAccel + 0.20*priorCompr
expansionScore = math.round(clamp01(expansionRaw) * 100)

zComp = clamp01(math.abs(midPos) / 2.5)
wComp = clamp01(wickRat / 0.65)
rComp = clamp01(rejCnt / 3.0)
fComp = clamp01(fade)
exhaustRaw    = 0.30*zComp + 0.25*wComp + 0.25*rComp + 0.20*fComp
exhaustScore  = math.round(clamp01(exhaustRaw) * 100)

// ─── STATE FLAGS ─────────────────────────────────────────────────────────────
maxPosWin = ta.highest(pos, behaviorLen)
minPosWin = ta.lowest(pos,  behaviorLen)
failedBull = maxPosWin > 0.70 and maxPosWin < 0.92 and pos < 0.50 and absRetF < absRetSm
failedBear = minPosWin < 0.30 and minPosWin > 0.08 and pos > 0.50 and absRetF < absRetSm
isFailed = failedBull or failedBear

isDistortion = flipCount >= 3 and (atrR > 1.4 or (cadence > 0.5 and directionality < 0.30))

nearMid   = math.abs(pos - 0.5) < 0.20
weakSlope = slopAbsA < 0.05
isDrift   = nearMid and weakSlope and midCrosses >= 3 and compressScore < cThresh

// ─── STATE CLASSIFIER (priority cascade) ─────────────────────────────────────
state = "NEUTRAL"
stateColor = cNeutral
if isDistortion
    state := "DISTORTION"
    stateColor := cDistortion
else if exhaustScore >= eThresh
    state := "EXHAUSTION"
    stateColor := cExhaustion
else if isFailed
    state := "FAILED"
    stateColor := cFailed
else if expansionScore >= xThresh and atrR > 1.0
    state := "EXPANSION"
    stateColor := cExpansion
else if compressScore >= cThresh
    state := "COMPRESSION"
    stateColor := cCompression
else if qualityScore >= qThresh and slopAbsA > 0.05
    state := "TRAVERSAL"
    stateColor := cTraversal
else if isDrift
    state := "DRIFT"
    stateColor := cDrift

stateLabel = state == "TRAVERSAL"   ? "Clean Traversal"     :
             state == "EXPANSION"   ? "Expansion Burst"     :
             state == "COMPRESSION" ? "Compression Coil"    :
             state == "EXHAUSTION"  ? "Exhaustion"          :
             state == "FAILED"      ? "Failed Traversal"    :
             state == "DISTORTION"  ? "Volatility Distort." :
             state == "DRIFT"       ? "Equilibrium Drift"   : "Neutral"

// ─── CHANNEL VISUAL ──────────────────────────────────────────────────────────
pM = plot(showChannel ? mid   : na, "Mid",   color=cMid,  linewidth=1)
pU = plot(showChannel ? upper : na, "Upper", color=cRail, linewidth=1)
pL = plot(showChannel ? lower : na, "Lower", color=cRail, linewidth=1)
fillC = not showFill ? na : color.new(stateColor, 92)
fill(pU, pL, color=fillC, title="Channel Fill")

bgcolor(showRibbon and state != "NEUTRAL" ? color.new(stateColor, 90) : na, title="State Ribbon")
barcolor(colorBars ? stateColor : na)

// ─── LIQUIDITY MEMORY ZONES ──────────────────────────────────────────────────
ph = ta.pivothigh(high, pivotL, pivotR)
pl_= ta.pivotlow (low,  pivotL, pivotR)

var line[]  hiLn = array.new<line>()
var float[] hiLv = array.new<float>()
var bool[]  hiTk = array.new<bool>()
var line[]  loLn = array.new<line>()
var float[] loLv = array.new<float>()
var bool[]  loTk = array.new<bool>()

if showZones and not na(ph)
    px = bar_index - pivotR
    ln = line.new(px, ph, bar_index, ph, color=cLqLive, width=1, extend=extend.right)
    array.push(hiLn, ln)
    array.push(hiLv, ph)
    array.push(hiTk, false)
    if array.size(hiLn) > maxZones
        line.delete(array.shift(hiLn))
        array.shift(hiLv)
        array.shift(hiTk)

if showZones and not na(pl_)
    px = bar_index - pivotR
    ln = line.new(px, pl_, bar_index, pl_, color=cLqLive, width=1, extend=extend.right)
    array.push(loLn, ln)
    array.push(loLv, pl_)
    array.push(loTk, false)
    if array.size(loLn) > maxZones
        line.delete(array.shift(loLn))
        array.shift(loLv)
        array.shift(loTk)

if showZones and array.size(hiLn) > 0
    for i = 0 to array.size(hiLn) - 1
        if not array.get(hiTk, i) and high > array.get(hiLv, i)
            array.set(hiTk, i, true)
            line.set_color(array.get(hiLn, i), cLqTaken)
            line.set_style(array.get(hiLn, i), line.style_dotted)

if showZones and array.size(loLn) > 0
    for i = 0 to array.size(loLn) - 1
        if not array.get(loTk, i) and low < array.get(loLv, i)
            array.set(loTk, i, true)
            line.set_color(array.get(loLn, i), cLqTaken)
            line.set_style(array.get(loLn, i), line.style_dotted)

// ─── DASHBOARD ───────────────────────────────────────────────────────────────
tablePos = dashPos == "top_left"     ? position.top_left  :
           dashPos == "top_right"    ? position.top_right :
           dashPos == "bottom_left"  ? position.bottom_left : position.bottom_right

var table dash = table.new(tablePos, 3, 8,
     bgcolor=color.new(#0d1117, 15), border_width=1, border_color=color.new(#1f2733, 40))

if showDash and barstate.islast
    table.cell(dash, 0, 0, "STATE",      text_color=cTextDim,    text_size=size.small)
    table.cell(dash, 1, 0, stateLabel,   text_color=stateColor,  text_size=size.small)
    table.cell(dash, 2, 0, "",           text_color=cText,       text_size=size.small)

    table.cell(dash, 0, 1, "Quality",  text_color=cTextDim,     text_size=size.tiny)
    table.cell(dash, 1, 1, makeBar(qualityScore),  text_color=cTraversal,   text_size=size.tiny)
    table.cell(dash, 2, 1, str.tostring(qualityScore),  text_color=cText,   text_size=size.tiny)

    table.cell(dash, 0, 2, "Compress", text_color=cTextDim,     text_size=size.tiny)
    table.cell(dash, 1, 2, makeBar(compressScore), text_color=cCompression, text_size=size.tiny)
    table.cell(dash, 2, 2, str.tostring(compressScore), text_color=cText,   text_size=size.tiny)

    table.cell(dash, 0, 3, "Expansion",text_color=cTextDim,     text_size=size.tiny)
    table.cell(dash, 1, 3, makeBar(expansionScore),text_color=cExpansion,   text_size=size.tiny)
    table.cell(dash, 2, 3, str.tostring(expansionScore),text_color=cText,   text_size=size.tiny)

    table.cell(dash, 0, 4, "Exhaust",  text_color=cTextDim,     text_size=size.tiny)
    table.cell(dash, 1, 4, makeBar(exhaustScore),  text_color=cExhaustion,  text_size=size.tiny)
    table.cell(dash, 2, 4, str.tostring(exhaustScore),  text_color=cText,   text_size=size.tiny)

    table.cell(dash, 0, 5, "ATR Ratio",text_color=cTextMute,    text_size=size.tiny)
    table.cell(dash, 1, 5, str.tostring(atrR, "#.##"),  text_color=cTextDim, text_size=size.tiny)
    table.cell(dash, 2, 5, "", text_size=size.tiny)

    table.cell(dash, 0, 6, "Position", text_color=cTextMute,    text_size=size.tiny)
    table.cell(dash, 1, 6, str.tostring(pos*100, "#")+"%",  text_color=cTextDim, text_size=size.tiny)
    table.cell(dash, 2, 6, "", text_size=size.tiny)

    table.cell(dash, 0, 7, "Direction",text_color=cTextMute,    text_size=size.tiny)
    table.cell(dash, 1, 7, str.tostring(directionality*100, "#")+"%", text_color=cTextDim, text_size=size.tiny)
    table.cell(dash, 2, 7, "", text_size=size.tiny)

// ─── ALERTS ──────────────────────────────────────────────────────────────────
stateChanged = state != state[1]
alertcondition(stateChanged and state == "TRAVERSAL",   "Clean Traversal",     "vX: Clean Traversal engaged")
alertcondition(stateChanged and state == "COMPRESSION", "Compression Coil",    "vX: Compression Coil")
alertcondition(stateChanged and state == "EXPANSION",   "Expansion Burst",     "vX: Expansion Burst")
alertcondition(stateChanged and state == "EXHAUSTION",  "Exhaustion",          "vX: Exhaustion state")
alertcondition(stateChanged and state == "FAILED",      "Failed Traversal",    "vX: Failed Traversal")
alertcondition(stateChanged and state == "DISTORTION",  "Volatility Distort.", "vX: Volatility Distortion")
alertcondition(stateChanged and state == "DRIFT",       "Equilibrium Drift",   "vX: Equilibrium Drift")
